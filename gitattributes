# Set default line endings to LF (Unix-style)
# This prevents Windows CRLF issues
* text=auto

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Binary files (don't change line endings)
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
